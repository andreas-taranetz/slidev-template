{
  "name": "slidev-template",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "slidev build",
    "dev": "slidev --open",
    "start": "slidev --open",
    "export": "slidev export"
  },
  "dependencies": {
    "@iconify-json/logos": "latest",
    "@iconify-json/simple-icons": "latest",
    "@slidev/cli": "^52.15.2",
    "@slidev/theme-default": "latest",
    "qrcode.vue": "^3.9.0",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-slidev": "^1.0.5"
  },
  "prettier": {
    "overrides": [
      {
        "files": [
          "slides.md",
          "pages/*.md"
        ],
        "options": {
          "parser": "slidev",
          "plugins": [
            "prettier-plugin-slidev"
          ]
        }
      }
    ]
  }
}
